/**
 * Returns true if redirection_data exists in localStorage and its
 * expires_at date is today.
 */
function hasValidExistingRedirectionData() {
    try {
        var stored = JSON.parse(localStorage.getItem('redirection_data'));
        if (!stored || !stored.expires_at) { return false; }
        var expiresDate = stored.expires_at.substring(0, 10); // "YYYY-MM-DD"
        var todayDate = new Date().toISOString().substring(0, 10);
        return expiresDate >= todayDate;
    } catch (e) {
        return false;
    }
}

/**
 * If the current page is Bell_TV/TV-Programming-Packages (or FR equivalent) and valid
 * redirection_data exists in localStorage, pre-populate the hidden address fields and
 * trigger qualification automatically — no manual address entry required.
 *
 * tvPackagesPageUrl is rendered as a JS global by CentralHowtoBuy_BRF.cshtml from the
 * link_packagesat resource (EN: /Bell_TV/TV-Programming-Packages,
 * FR: /Bell_Tele/Forfaits-programmation). Fall back to the EN value if not defined.
 */
function autoQualifyFromRedirectionData() {
    var tvPkgUrl = (typeof tvPackagesPageUrl !== 'undefined' && tvPackagesPageUrl)
        ? tvPackagesPageUrl
        : '/Bell_TV/TV-Programming-Packages';
    if (window.location.href.indexOf(tvPkgUrl) === -1) { return; }
    if (!hasValidExistingRedirectionData()) { return; }

    // Address was already qualified this session — redirection_data has served its purpose.
    // Clean it up so it does not re-trigger auto-qualification on future visits (new tab / new session).
    if (sessionStorage.getItem('qualifiedAddress')) {
        localStorage.removeItem('redirection_data');
        return;
    }

    try {
        var stored = JSON.parse(localStorage.getItem('redirection_data'));
        if (!stored) { return; }

        // Populate hidden address form fields used by ValidateHowtoBuyAddressCallback
        $('#streetNumber').val(stored.StreetNumber || '');
        $('#streetName').val(stored.StreetName || '');
        $('#streetType').val(stored.StreetType || '');
        $('#streetPreDirection').val(stored.StreetDirection || stored.StreetPreDirection || '');
        $('#streetPostDirection').val(stored.StreetPostDirection || '');
        $('#subBuilding').val(stored.ApartmentNumber || stored.SubBuilding || '');
        $('#city').val(stored.City || '');
        $('#state').val(stored.Province || stored.ProvinceState || '');
        $('#postalCode').val(stored.PostalCode || stored.PostalZip || '');
        $('#building').val(stored.Building || '');

        // Populate the address display field so isFromModalPopup is set to true
        // inside ValidateHowtoBuyAddressCallback, which triggers GetIndexOfSelectedAddressSingleHtB
        var displayAddress = [
            stored.StreetNumber,
            stored.StreetName,
            stored.StreetType,
            stored.City,
            stored.Province || stored.ProvinceState,
            stored.PostalCode || stored.PostalZip
        ].filter(Boolean).join(' ');
        $('#ValidationAddressHowtoBuy').val(displayAddress);

        ValidateHowtoBuyAddressCallback(null, true);
    } catch (e) {
        console.error('autoQualifyFromRedirectionData error:', e);
    }
}

