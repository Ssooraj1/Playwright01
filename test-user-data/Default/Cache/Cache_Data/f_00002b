                        s_oARS: obj[0].ErrorCode,
                        s_oERR_CLASS: obj[0].ERR_CLASS,
                        s_oERR_DESC: obj[0].ERR_DESC,
                        s_oPLE: s_oPLE_Value
                    });
                }
                catch (e) {
                }

            }
        });

    }
    else {
        return false;
    }
}

