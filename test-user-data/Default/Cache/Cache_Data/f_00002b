//  As per CR-38944 bundles and CR-39943
function clearH(eqh) {
    $('.' + eqh).removeAttr('style');
    eqHJs(eqh);
}

//  As per CR-38944 bundles and CR-39943
function eqHJs(eqh) {
    var maxHeight = 0;

    $('.' + eqh).each(function () {
        var itemHeight = parseInt($(this).outerHeight());
        if (itemHeight > maxHeight) maxHeight = itemHeight;
    });
    $('.' + eqh).css('height', maxHeight);
    maxHeight = 0;
}

